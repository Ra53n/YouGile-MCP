{
  "name": "yougile-mcp-server",
  "version": "1.0.0",
  "description": "MCP (Model Context Protocol) server for YouGile — connect an AI agent to your YouGile boards and tasks (read + safe writes). Supports stdio (local) and Streamable HTTP (remote) transports.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "yougile-mcp-server": "dist/index.js",
    "yougile-get-key": "dist/get-key.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "get-key": "tsx src/get-key.ts",
    "inspect": "npm run build && npx @modelcontextprotocol/inspector node dist/index.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "yougile",
    "kanban",
    "task-management",
    "claude",
    "ai-agent"
  ],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "axios": "^1.7.9",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
