# Server environment for the remote (HTTP) deployment.
# On the VPS this is written to /etc/yougile-mcp.env with chmod 600.
# deploy.sh fills these in from your answers; you can also edit by hand.

# Transport — must be http for the remote server.
TRANSPORT=http

# Port the Node process listens on (bound to 127.0.0.1, fronted by Caddy/TLS).
PORT=3000

# Your YouGile API key (Bearer). Get it with `npm run get-key`.
YOUGILE_API_KEY=

# API base URL (region).
YOUGILE_BASE_URL=https://ru.yougile.com/api-v2

# Bearer token clients must send to reach /mcp. Generate: openssl rand -hex 32
MCP_AUTH_TOKEN=

# Public hostname clients connect to (domain or <dashed-ip>.sslip.io).
# Used for DNS-rebinding protection and by Caddy for TLS.
MCP_PUBLIC_HOST=

# Optional — your YouGile user id, enables my_tasks / overdue_tasks "me".
# YOUGILE_USER_ID=
