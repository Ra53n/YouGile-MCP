# ─────────────────────────────────────────────────────────────────────────────
# YouGile MCP server — environment variables
# Copy to `.env` for local dev (never commit .env). On the VPS this lives in
# /etc/yougile-mcp.env (see deploy/). Get an API key with: npm run get-key
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — your YouGile API key (Bearer token). The server uses ONLY this key;
# your password is never stored. Generate it in YouGile (Settings → API keys)
# or run `npm run get-key`.
YOUGILE_API_KEY=

# Optional — API base URL. Default: https://ru.yougile.com/api-v2
# Use https://yougile.com/api-v2 if that is your region's host.
YOUGILE_BASE_URL=https://ru.yougile.com/api-v2

# Optional — your YouGile user id. Lets `yougile_my_tasks` / `yougile_overdue_tasks`
# resolve "me". Find it via the `yougile_list_users` tool (filter by your email).
YOUGILE_USER_ID=

# ── Transport ────────────────────────────────────────────────────────────────
# stdio (default) = local subprocess for Claude Desktop / Cursor.
# http            = remote Streamable HTTP server (requires MCP_AUTH_TOKEN).
TRANSPORT=stdio

# ── HTTP transport only (TRANSPORT=http) ─────────────────────────────────────
# Port the HTTP server listens on (bound to 127.0.0.1; expose via reverse proxy).
PORT=3000

# REQUIRED in http mode — bearer token clients must send to reach /mcp.
# Use a long random value, e.g.: openssl rand -hex 32
MCP_AUTH_TOKEN=

# Optional — public hostname for DNS-rebinding protection (the Host header your
# reverse proxy forwards), e.g. yougile.example.com or 203-0-113-7.sslip.io
MCP_PUBLIC_HOST=
